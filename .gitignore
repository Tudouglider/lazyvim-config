# =============================================================================
# LazyVim / Neovim 配置 .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# LazyVim 自动生成的文件（不需要同步）
# -----------------------------------------------------------------------------

# Lazy.nvim 插件管理器生成的文件
# lazy-lock.json

# Mason 安装的 LSP/DAP/格式化工具（自动下载）
# 注意：如果你需要锁定工具版本，可以注释掉下面这行
# 但通常这些工具应该在目标机器上重新安装
.mason/

# 插件数据缓存
lazyvim.json

# -----------------------------------------------------------------------------
# Neovim 运行时生成的文件
# -----------------------------------------------------------------------------

# 会话文件
session/

# 交换文件和备份（如果不放在默认位置）
*.swp
*.swo
*~
*.tmp

# Undo 历史（如果不使用持久化 undo 或不想同步）
# 如果你想跨设备同步编辑历史，可以注释掉下面这行
undo/

# 备份文件
backup/

# Shada 文件（Neovim 的共享数据，包含寄存器、命令历史等）
# 通常包含敏感信息，不建议同步
shada/

# 日志文件
log/
*.log

# -----------------------------------------------------------------------------
# 操作系统生成的文件
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# 编辑器/IDE 生成的文件
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/

# -----------------------------------------------------------------------------
# 敏感信息（千万不要同步！）
# -----------------------------------------------------------------------------

# 可能包含 API keys、路径等敏感信息的配置文件
# 如果你有自定义的 secrets 文件
*.secret
*.secrets
.env
.env.local

# 包含机器特定路径或敏感数据的配置文件
# 例如某些插件的数据库连接配置等
lua/config/secrets.lua
lua/plugins/secrets.lua

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------

# 临时下载的文件
downloads/
tmp/
temp/

# 测试文件（如果你本地测试用的）
test/
tests/
